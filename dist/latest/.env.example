COMPOSE_PROJECT_NAME=souz

# Public routing
DOMAIN=example.com
PUBLIC_BASE_URL=https://example.com
HOST_PROXY_PORT=18080
SOUZ_VERSION=latest

# Required secrets
SOUZ_BACKEND_PROXY_TOKEN=replace_me_long_random_value
SOUZ_MASTER_KEY=replace_me_long_random_value
TELEGRAM_TOKEN_ENCRYPTION_KEY=replace_me_long_random_value

PROXY_DB_PASSWORD=replace_me
BACKEND_DB_PASSWORD=replace_me

SESSION_HASH_SECRET=replace_me_long_random_value
WELCOME_KEY_SECRET=replace_me_long_random_value

# Proxy runtime tuning
# PROXY_HOST=0.0.0.0
# PROXY_PORT=8080
# BACKEND_URL=http://souz-backend:8080
# COOKIE_NAME=souz_session
# COOKIE_SECURE=true
# SESSION_TTL_DAYS=30
# PROXY_ENV=production
# WS_ALLOWED_ORIGINS=https://example.com
# WS_MAX_FRAME_SIZE_BYTES=1048576
# WS_PING_PERIOD_SECONDS=15
# WS_IDLE_TIMEOUT_SECONDS=30
# AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
# AUTH_RATE_LIMIT_WINDOW_SECONDS=300
# BACKEND_REQUEST_TIMEOUT_SECONDS=30

# Backend runtime tuning
# SOUZ_BACKEND_HOST=0.0.0.0
# SOUZ_BACKEND_PORT=8080
# SOUZ_STORAGE_MODE=postgres
# SOUZ_BACKEND_DB_HOST=backend-db
# SOUZ_BACKEND_DB_PORT=5432
# SOUZ_BACKEND_DB_NAME=souz
# SOUZ_BACKEND_DB_USER=souz
# SOUZ_BACKEND_DB_SCHEMA=public
# SOUZ_BACKEND_DB_MAX_POOL_SIZE=10
# SOUZ_BACKEND_DB_CONNECTION_TIMEOUT_MS=30000
# SOUZ_BACKEND_DATA_DIR=data

# Backend feature flags
# ENABLE_BACKEND_TG_FEATURE=true
# SOUZ_FEATURE_WS_EVENTS=true
# SOUZ_FEATURE_STREAMING_MESSAGES=true
# SOUZ_FEATURE_TOOL_EVENTS=true
# SOUZ_FEATURE_OPTIONS=true
# SOUZ_FEATURE_DURABLE_EVENT_REPLAY=true

# Backend quotas and provider retry policy
# SOUZ_BACKEND_LIMIT_PER_USER_CONCURRENT_EXECUTIONS=4
# SOUZ_BACKEND_LIMIT_PER_USER_REQUESTS_PER_MINUTE=30
# SOUZ_BACKEND_LIMIT_PER_USER_TOKENS_PER_MINUTE=120000
# SOUZ_BACKEND_LIMIT_GLOBAL_PROVIDER_CONCURRENCY=8
# SOUZ_BACKEND_PROVIDER_MAX_429_RETRIES=2
# SOUZ_BACKEND_PROVIDER_BACKOFF_BASE_MS=500
# SOUZ_BACKEND_PROVIDER_BACKOFF_MAX_MS=5000
# SOUZ_BACKEND_SYSTEM_PROMPT=

# Optional server-managed provider keys.
# Leave these commented out for user-managed provider keys.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5-nano
# OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# QWEN_KEY=
# QWEN_MODEL=qwen-flash
# QWEN_EMBEDDINGS_MODEL=text-embedding-v3
# AITUNNEL_KEY=
# AITUNNEL_MODEL=gpt-4o-mini
# AITUNNEL_EMBEDDINGS_MODEL=text-embedding-3-small
# GIGA_KEY=
GIGA_LOG_LEVEL=INFO
